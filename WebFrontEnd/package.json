{
  "private": true,
  "scripts": {
    "build": "npm run build:css && npm run build:ts && npm run build:html && npm run build:vendor",
    "build:css": "npx @tailwindcss/cli -i src/input.css -o wwwroot/styles.css --minify",
    "build:ts": "npx esbuild src/dashboard.ts --bundle --minify --outfile=wwwroot/dashboard.js",
    "build:html": "node -e \"require('fs').cpSync('src/index.html','wwwroot/index.html')\"",
    "build:vendor": "node -e \"require('fs').cpSync('node_modules/htmx.org/dist/htmx.min.js','wwwroot/htmx.min.js')\""
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "esbuild": "^0.25.0",
    "htmx.org": "^2.0.0"
  }
}
