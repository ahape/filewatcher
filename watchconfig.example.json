{
  "$schema": "./watchconfig.schema.json",
  "settings": {
    "debounceMs": 1000,
    "logLevel": "Debug"
  },
  "hooks": {
    "onStartup": [
      {
        "location": "c:\\Users\\AlanHape\\source\\repos\\Azurite\\",
        "command": "pwsh -ExecutionPolicy Bypass -NoProfile -File ./Scripts/Run-Azurite.ps1",
        "logLevel": "None"
      },
      {
        "name": "IIS Express",
        "command": "powershell -ExecutionPolicy Bypass -NoProfile -File ./Scripts/Start-IIS.ps1",
        "logLevel": "Info"
      }
    ],
    "onUpdate": [
      {
        "source": "c:\\src\\projects\\BrightMetricsWeb\\BrightMetricsWeb.BrightMetricsWebUI\\UI-2\\scripts\\build\\brightmetrics.js",
        "location": "c:\\src\\projects\\BrightMetricsWeb\\BrightMetricsWeb.BrightMetricsWebUI\\UI-2\\",
        "command": "npm run lint",
        "description": "TS/JS Linter"
      },
      {
        "source": "c:\\src\\projects\\BrightMetricsWeb\\BrightMetricsWeb.BrightMetricsWebUI\\UI-2\\scripts\\build\\brightmetrics.js",
        "copyTo": "c:\\src\\azure\\BrightmetricsWeb\\UI-2\\scripts\\build\\brightmetrics.js",
        "description": "Main Javascript bundle (copy to server)"
      }
    ]
  }
}

