{
  "$schema": "./watchconfig.schema.json",
  "settings": {
    "debounceMs": 1000,
    "createBackups": false,
    "logLevel": "Info"
  },
  "hooks": {
    "onStartup": {
      "location": "c:\\src\\projects\\BrightMetricsWeb\\BrightMetricsWeb.BrightMetricsWebUI\\UI-2\\",
      "command": "npx tsc -w -p tsconfig.development.json"
    },
    "onUpdate": {
      "location": "c:\\src\\projects\\BrightMetricsWeb\\BrightMetricsWeb.BrightMetricsWebUI\\UI-2\\",
      "command": "npm run ts:lint"
    }
  },
  "mappings": [
    {
      "source": "c:\\src\\projects\\BrightMetricsWeb\\BrightMetricsWeb.BrightMetricsWebUI\\UI-2\\scripts\\build\\brightmetrics.js",
      "destination": "c:\\src\\azure\\BrightmetricsWeb\\UI-2\\scripts\\build\\brightmetrics.js",
      "enabled": true,
      "description": "Main JavaScript bundle"
    },
    {
      "source": "c:\\src\\projects\\BrightMetricsWeb\\BrightMetricsWeb.BrightMetricsWebUI\\UI-2\\styles\\build\\brightmetrics.css",
      "destination": "c:\\src\\azure\\BrightmetricsWeb\\UI-2\\styles\\build\\brightmetrics.css",
      "enabled": true,
      "description": "Main stylesheet"
    },
    {
      "source": "c:\\src\\projects\\BrightMetricsWeb\\BrightMetricsWeb.BrightMetricsWebUI\\UI-2\\templates\\admin\\datacustomization\\ccf-editor-view.html",
      "destination": "c:\\src\\azure\\BrightmetricsWeb\\UI-2\\templates\\admin\\datacustomization\\ccf-editor-view.html",
      "enabled": true,
      "description": "CCF Editor View"
    }
  ]
}
