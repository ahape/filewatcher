{
  "settings": {
    "debounceMs": 500,
    "logLevel": "Debug"
  },
  "hooks": {
    "onStartup": {
      "location": "./scripts",
      "command": "echo 'Starting up!'"
    },
    "onUpdate": {
      "listenTo": "my-app-bundle",
      "location": "./src/app",
      "command": "echo 'Bundle updated.'"
    }
  },
  "mappings": [
    {
      "id": "my-app-bundle",
      "source": "./src/app/bundle.js",
      "destination": "./dist/app.js",
      "description": "Main application javascript bundle"
    },
    {
      "source": "./assets/styles/main.css",
      "destination": "./public/css/styles.css",
      "enabled": false,
      "description": "Main CSS file (currently disabled)"
    }
  ]
}
