{
  "$schema": "./watchconfig.schema.json",
  "settings": {
    "debounceMs": 1000
  },
  "hooks": {
    "onStartup": [
      {
        "name": "Azurite",
        "command": "azurite --silent --location ./.startup-content/azurite/workspace"
      },
      {
        "name": "IIS Express",
        "command": "pwsh -ExecutionPolicy Bypass -NoProfile -File ./Scripts/Start-IIS.ps1",
        "enabled": false
      },
      {
        "name": "TypeScript Watcher",
        "command": "npx --prefix /src/projects/BrightMetricsWeb/BrightMetricsWeb.BrightMetricsWebUI/UI-2/ -- tsc -w -p /src/projects/BrightMetricsWeb/BrightMetricsWeb.BrightMetricsWebUI/UI-2/tsconfig.development.json --pretty false --preserveWatchOutput"
      },
      {
        "name": "Web Logs",
        "command": "pwsh -ExecutionPolicy Bypass -NoProfile -Command 'Write-Output $null > $env:TMP/bmweblog2.txt && Get-Content $env:TMP/bmweblog2.txt -Wait'"
      }
    ],
    "onUpdate": [
      {
        "name": "Lint Typescript",
        "source": "c:\\src\\projects\\BrightMetricsWeb\\BrightMetricsWeb.BrightMetricsWebUI\\UI-2\\scripts\\build\\brightmetrics.js",
        "location": "c:\\src\\projects\\BrightMetricsWeb\\BrightMetricsWeb.BrightMetricsWebUI\\UI-2\\",
        "command": "npm run lint --silent && echo OK"
      },
      {
        "name": "Copy JS to Server",
        "source": "c:\\src\\projects\\BrightMetricsWeb\\BrightMetricsWeb.BrightMetricsWebUI\\UI-2\\scripts\\build\\brightmetrics.js",
        "copyTo": "c:\\src\\azure\\BrightmetricsWeb\\UI-2\\scripts\\build\\brightmetrics.js"
      }
    ]
  }
}
